# Trading System Configuration
# Copy this file to .env and fill in your actual API credentials

# Binance Configuration (for data fetching)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_SANDBOX=false

# Bybit Configuration (for trading)
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_SECRET_KEY=your_bybit_secret_key_here
BYBIT_SANDBOX=true

# Trading Parameters
TRADING_SYMBOL=BTC/USDT
POSITION_SIZE=0.01

# Z-score Strategy Parameters
ZSCORE_LONG_THRESHOLD=1.3
ZSCORE_SHORT_THRESHOLD=-1.3

# Data Parameters
LOOKBACK_PERIOD=20
DATA_FETCH_INTERVAL=300

# Risk Management
MAX_POSITION_SIZE=0.1
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10

# Logging
LOG_LEVEL=INFO
LOG_FILE=trading_system.log